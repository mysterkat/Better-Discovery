# Node / frontend
node_modules/
dist/
.vite/
*.log

# Rust / Tauri
src-tauri/target/
src-tauri/binaries/python/*
!src-tauri/binaries/python/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# User data (portable; contents are user-owned)
userdata/**
!userdata/.gitkeep
!userdata/themes/.gitkeep
!userdata/recent/.gitkeep
!userdata/cache/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Claude Code worktrees
.claude/

# Stray tilde folder (Tauri signer wrote keys here when path was unexpanded)
~/

# Tauri signing keys — never commit
*.key
*.key.pub

# Compiled MQL5 binaries (rebuilt from .mq5 via MetaEditor)
*.ex5

# Local-only doc backups
*.local.bak.md

# Runtime discovery settings contain machine-specific paths and seeds
backend/toolkit/_app_override.json
