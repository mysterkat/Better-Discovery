{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BETTER DISCOVERY",
  "version": "2.2.1",
  "identifier": "com.betterdiscovery.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "BETTER DISCOVERY",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Monte Carlo + pattern discovery desktop app",
    "longDescription": "Standalone desktop app wrapping the MONTE CARLO toolkit.",
    "copyright": "",
    "publisher": "BETTER DISCOVERY",
    "resources": {
      "../backend": "backend"
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "languages": [
          "English"
        ]
      },
      "wix": {}
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/mysterkat/better-discovery-releases/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1MTQ4RjQ1MjREODBBOTkKUldTWkN0Z2tSWThVcFQ3aXdSbm1uck5OYUZxcXppSHFuWDgzYzVCYWJGZDRJa0R6Q2x2eFBvSnEK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
